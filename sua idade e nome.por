programa {
  funcao inicio() {
    cadeia nome
    inteiro anoNascimento
    inteiro idade
    escreva("informe o seu nome: ")
    leia(nome)
    escreva("informe seu ano de nascimento: ")
    leia(anoNascimento)

    idade = 2026 - anoNascimento 

    escreva("Olá",nome," sua idade é: ",idade," anos.")
    
  }
}
